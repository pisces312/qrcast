{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "V2 Generate (README.md -> QR canvases)",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.bw.generator",
            "args": [
                "${workspaceFolder}/README.md",
                "--output-dir",
                "./tmp"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "V2 Generate with compress",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.bw.generator",
            "args": [
                "${workspaceFolder}/README.md",
                "--output-dir",
                "./tmp",
                "--compress"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "V2 Quick Send (env.yml -> single QR)",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.bw.quick_sender",
            "args": [
                "${workspaceFolder}/env.yml",
                "--ver", "20"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "V2 Verify",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.bw.verifier",
            "args": [
                "./tmp",
                "./tmp/verify_output"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "V3 Generate Bin",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.rgb.generator_bin",
            "args": [
                "${workspaceFolder}/README.md",
                "--output-dir",
                "./tmp"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "V3 Generate Text",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.rgb.generator_text",
            "args": [
                "${workspaceFolder}/README.md",
                "--output-dir",
                "./tmp"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "V3 Verify Bin",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.rgb.verifier_bin",
            "args": [
                "./tmp",
                "./tmp/qrgb_bin_verify_output"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "V3 Verify Text",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.rgb.verifier_text",
            "args": [
                "./tmp",
                "./tmp/qrgb_verify_output"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Display QR Canvases",
            "type": "debugpy",
            "request": "launch",
            "module": "qrcast.common",
            "args": [
                "./tmp"
            ],
            "cwd": "${workspaceFolder}/sender",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
