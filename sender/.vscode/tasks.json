{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Python: Run all tests",
            "type": "shell",
            "command": "D:/nili/dev/conda_envs/qrcast_env/python.exe -m pytest tests/ -v",
            "cwd": "${workspaceFolder}/sender",
            "group": "sender",
            "problemMatcher": []
        },
        {
            "label": "V3 Generate Bin",
            "type": "shell",
            "command": "D:/nili/dev/conda_envs/qrcast_env/python.exe",
            "args": [
